# ============================================================================
# TinyRAG — Environment Variables Template
# ----------------------------------------------------------------------------
# Copy this file to `.env` (which is gitignored) and fill in any non-default
# values. Settings prefixed with TINYRAG_ can also be passed as plain env vars
# to override config.yaml. Pydantic-settings reads them in this order:
#
#   1. Defaults from config.yaml
#   2. Environment variables (TINYRAG_*)
#   3. .env file (loaded by python-dotenv)
#
# DO NOT put secrets here. TinyRAG is designed to run offline; there are no
# API keys. If you ever DO need one, use the secret manager on the Pi, not
# this file.
# ============================================================================


# ---- Logging ----
# Override the log level. Default: INFO. Options: DEBUG, INFO, WARNING, ERROR.
# TINYRAG_LOG_LEVEL=INFO

# Set to "true" to include query text and answers in logs.
# WARNING: may include personal data. Default: false. See SECURITY.md §6.
# TINYRAG_LOG_INCLUDE_PII=false


# ---- LLM server ----
# Override the llama.cpp HTTP server URL. Default: http://127.0.0.1:8080
# TINYRAG_LLAMACPP_BASE_URL=http://127.0.0.1:8080

# Override the primary model id (as listed in config.yaml under models).
# Default: phi3-mini
# TINYRAG_LLAMACPP_PRIMARY_MODEL=phi3-mini


# ---- API server ----
# Override the FastAPI bind host. Default: 127.0.0.1 (loopback only).
# For LAN access, change to 0.0.0.0 AND put behind a reverse proxy.
# TINYRAG_API_HOST=127.0.0.1

# Override the FastAPI port. Default: 8000.
# TINYRAG_API_PORT=8000


# ---- Sensor source ----
# Override the sensor source. Default: simulated.
# Options: simulated, serial, mqtt
# TINYRAG_SENSORS_SOURCE=simulated

# MQTT broker URL (only used if TINYRAG_SENSORS_SOURCE=mqtt).
# TINYRAG_SENSORS_MQTT_BROKER=mqtt://localhost:1883


# ---- Vector store ----
# Override the FAISS index directory. Default: data/vector_store
# TINYRAG_VECTOR_STORE_DIR=data/vector_store

# Override the SQLite metadata DB path. Default: data/metadata.db
# TINYRAG_METADATA_DB_PATH=data/metadata.db
