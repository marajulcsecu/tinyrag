# ============================================================================
# TinyRAG — .gitignore
# ----------------------------------------------------------------------------
# This file tells git which paths to NEVER track. It is read top-to-bottom;
# later rules override earlier ones when patterns overlap.
#
# When in doubt: keep generated/large/private stuff OUT of the repo.
# Source code (src/, tests/, scripts/), docs (docs/), and config templates
# SHOULD be tracked. Build artifacts, model weights, user data, and runtime
# logs MUST NOT be tracked.
#
# Canonical spec: docs/05_tech_stack_v1.md §6, docs/04_database_design_v1.md §8
# ============================================================================


# ----------------------------------------------------------------------------
# 1. Python — bytecode, caches, packaging
# ----------------------------------------------------------------------------
# Generated by CPython and tools; never source.
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv
.venv/
venv/
env/
ENV/
.python-version

# pytest / coverage / mypy / ruff caches
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.cache
.mypy_cache/
.ruff_cache/
.pyright_cache/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# ----------------------------------------------------------------------------
# 2. Project data, models, and runtime artifacts
# ----------------------------------------------------------------------------
# These are the large / generated / user-specific dirs defined in
# docs/04_database_design_v1.md §8 and docs/06_roadmap_v2.md Step 3.1.
models/                     # downloaded GGUF weights (large, license-restricted)
data/documents/             # uploaded user PDFs/MD (user-private)
data/sensor_logs/           # raw + processed sensor CSVs (user-private)
data/vector_store/          # FAISS index files (regenerable from data/documents)
data/eval_logs/             # per-question eval logs from scripts/eval.py
data/metadata.db            # SQLite metadata DB
logs/                       # structured JSON logs from structlog
reports/                    # generated CSV / PDF reports (regenerable)
!reports/.gitkeep           # but keep the empty dir in git

# ----------------------------------------------------------------------------
# 3. Environment & secrets
# ----------------------------------------------------------------------------
# IMPORTANT: the allow-list (lines starting with !) MUST come AFTER the
# ignore rules they override — git applies .gitignore top-to-bottom and the
# last matching rule wins.
.env
.env.*
*.pem
*.key
secrets/
config.local.yaml           # local config overrides

# Allow-list (overrides the rules above).
# Use the FULL pattern to negate — wildcards in negation patterns don't
# work the way you'd expect in older git versions.
!.env.example               # template IS tracked (committed)
!.env.template              # alternate name, also tracked

# ----------------------------------------------------------------------------
# 4. IDE / editor
# ----------------------------------------------------------------------------
.idea/
.vscode/
!.vscode/settings.json      # allow shared settings
!.vscode/extensions.json
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace

# Puku CLI session data (AI agent state)
.puku-cli/

# ----------------------------------------------------------------------------
# 5. OS-specific
# ----------------------------------------------------------------------------
.Trash-*
.fseventsd/
.Spotlight-V100/
._*
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ----------------------------------------------------------------------------
# 6. Hardware / firmware (Phase 6 deployment)
# ----------------------------------------------------------------------------
*.bin
*.elf
*.hex
*.uf2

# ----------------------------------------------------------------------------
# 7. Logs and temp files
# ----------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
*.tmp
nul

# ----------------------------------------------------------------------------
# 8. Allow-list (force-include specific files even if parent dir is ignored)
# ----------------------------------------------------------------------------
# Keep the directory structure visible even when empty.
!docs/.gitkeep
!.github/.gitkeep
!scripts/.gitkeep
!src/.gitkeep
!tests/.gitkeep
